<?xml version="1.0" encoding="utf-8"?>
<ContentType Key="c9d0e1f2-0001-0001-0001-000000000001" Alias="lgContentReview" Level="1">
  <Info>
    <Name>LG Content Review</Name>
    <Icon>icon-certificate color-red</Icon>
    <Thumbnail>folder.png</Thumbnail>
    <Description>Content review tracking fields. Apply to any page type to enable content governance. Critical for LGR content migration and ongoing compliance.</Description>
    <AllowAtRoot>False</AllowAtRoot>
    <IsListView>False</IsListView>
    <Variations>Nothing</Variations>
    <IsElement>false</IsElement>
    <Folder>LocalGov/Compositions</Folder>
    <Compositions />
    <DefaultTemplate></DefaultTemplate>
    <AllowedTemplates />
  </Info>
  <Structure />
  <GenericProperties>
    <GenericProperty>
      <Key>c9d0e1f2-0001-0001-0001-000000000011</Key>
      <Name>Last Reviewed</Name>
      <Alias>lastReviewed</Alias>
      <Definition>5046194e-4237-453c-a547-15db3a07c4e1</Definition>
      <Type>Umbraco.DateTime</Type>
      <Mandatory>false</Mandatory>
      <Description><![CDATA[Date this content was last reviewed and confirmed accurate]]></Description>
      <SortOrder>1</SortOrder>
      <Tab Alias="review">Review</Tab>
      <Variations>Nothing</Variations>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>c9d0e1f2-0001-0001-0001-000000000012</Key>
      <Name>Next Review Due</Name>
      <Alias>nextReviewDue</Alias>
      <Definition>5046194e-4237-453c-a547-15db3a07c4e1</Definition>
      <Type>Umbraco.DateTime</Type>
      <Mandatory>true</Mandatory>
      <Description><![CDATA[Date by which this content must be reviewed. Mandatory — editors receive email reminders approaching this date.]]></Description>
      <SortOrder>2</SortOrder>
      <Tab Alias="review">Review</Tab>
      <Variations>Nothing</Variations>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>c9d0e1f2-0001-0001-0001-000000000013</Key>
      <Name>Review Owner</Name>
      <Alias>reviewOwner</Alias>
      <Definition>502223f4-15f9-48e1-89d2-7c5e949dd985</Definition>
      <Type>Custom.UserPicker</Type>
      <Mandatory>false</Mandatory>
      <Description><![CDATA[The Umbraco user responsible for reviewing this content. Used for automated email reminders.]]></Description>
      <SortOrder>3</SortOrder>
      <Tab Alias="review">Review</Tab>
      <Variations>Nothing</Variations>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>c9d0e1f2-0001-0001-0001-000000000014</Key>
      <Name>Review Comments</Name>
      <Alias>reviewComments</Alias>
      <Definition>c6bac0dd-4ab9-45b1-8e30-e4b619ee5da3</Definition>
      <Type>Umbraco.TextArea</Type>
      <Mandatory>false</Mandatory>
      <Description><![CDATA[Notes from the last review (e.g. changes made, reasons for next due date)]]></Description>
      <SortOrder>4</SortOrder>
      <Tab Alias="review">Review</Tab>
      <Variations>Nothing</Variations>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>c9d0e1f2-0001-0001-0001-000000000015</Key>
      <Name>Migration Source</Name>
      <Alias>migrationSource</Alias>
      <Definition>0cc0eba1-9960-42c9-bf9b-60e150b429ae</Definition>
      <Type>Umbraco.TextBox</Type>
      <Mandatory>false</Mandatory>
      <Description><![CDATA[For LGR migrations: the predecessor council this content was migrated from (e.g. "South Cambridgeshire District Council")]]></Description>
      <SortOrder>5</SortOrder>
      <Tab Alias="review">Review</Tab>
      <Variations>Nothing</Variations>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
  </GenericProperties>
  <Tabs>
    <Tab>
      <Key>c9d0e1f2-0001-0001-0001-000000000091</Key>
      <Caption>Review</Caption>
      <Alias>review</Alias>
      <Type>Tab</Type>
      <SortOrder>90</SortOrder>
    </Tab>
  </Tabs>
</ContentType>
