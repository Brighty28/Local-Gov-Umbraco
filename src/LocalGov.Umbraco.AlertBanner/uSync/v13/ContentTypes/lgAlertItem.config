<?xml version="1.0" encoding="utf-8"?>
<ContentType Key="c1a2b3c4-0060-0060-0060-000000000061" Alias="lgAlertItem" Level="3">
  <Info>
    <Name>LG Alert Item</Name>
    <Icon>icon-alert color-red</Icon>
    <Thumbnail>folder.png</Thumbnail>
    <Description>Single alert banner. Severity drives the GOV.UK notification banner colour.</Description>
    <AllowAtRoot>False</AllowAtRoot>
    <IsListView>False</IsListView>
    <Variations>Nothing</Variations>
    <IsElement>false</IsElement>
    <Folder>LocalGov/AlertBanner</Folder>
    <Compositions />
    <DefaultTemplate></DefaultTemplate>
    <AllowedTemplates />
  </Info>
  <Structure />
  <GenericProperties>
    <GenericProperty>
      <Key>c1a2b3c4-0060-0060-0060-000000000611</Key>
      <Name>Severity</Name>
      <Alias>severity</Alias>
      <Definition>c1a2b3c4-d000-d000-d000-000000000060</Definition>
      <Type>Umbraco.DropDown.Flexible</Type>
      <Mandatory>true</Mandatory>
      <Description><![CDATA[Severity drives the banner colour: Announcement (blue), Warning (yellow), Critical (red)]]></Description>
      <SortOrder>1</SortOrder>
      <Tab Alias="alert">Alert</Tab>
      <Variations>Nothing</Variations>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>c1a2b3c4-0060-0060-0060-000000000612</Key>
      <Name>Message</Name>
      <Alias>message</Alias>
      <Definition>ca90c950-0aff-4e72-b976-a30b1ac57dad</Definition>
      <Type>Umbraco.TinyMCE</Type>
      <Mandatory>true</Mandatory>
      <Description><![CDATA[The alert text (HTML allowed). Keep concise — banners are shown sitewide.]]></Description>
      <SortOrder>2</SortOrder>
      <Tab Alias="alert">Alert</Tab>
      <Variations>Nothing</Variations>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>c1a2b3c4-0060-0060-0060-000000000613</Key>
      <Name>Dismissible</Name>
      <Alias>dismissible</Alias>
      <Definition>92897bc6-a5f3-4ffe-ae27-f2e7e33dda49</Definition>
      <Type>Umbraco.TrueFalse</Type>
      <Mandatory>false</Mandatory>
      <Description><![CDATA[When enabled, visitors can close the banner and it stays hidden for the session]]></Description>
      <SortOrder>3</SortOrder>
      <Tab Alias="alert">Alert</Tab>
      <Variations>Nothing</Variations>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
  </GenericProperties>
  <Tabs>
