      <Type>Umbraco.MultiNodeTreePicker</Type>
      <Mandatory>false</Mandatory>
      <Description><![CDATA[Alerts shown only on this specific page]]></Description>
      <SortOrder>1</SortOrder>
      <Tab Alias="alerts">Alerts</Tab>
