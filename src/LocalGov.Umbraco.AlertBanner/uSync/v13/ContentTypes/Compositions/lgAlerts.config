  <Info>
    <Name>LG Alerts</Name>
    <Icon>icon-chat-active color-red</Icon>
    <Thumbnail>folder.png</Thumbnail>
    <Description>Composition that adds alert pickers to content pages. Apply this to any page type that should be able to display alerts.</Description>
    <AllowAtRoot>False</AllowAtRoot>
    <IsListView>False</IsListView>
    <Variations>Nothing</Variations>
    <IsElement>false</IsElement>
    <Folder>LocalGov/Compositions</Folder>
    <Compositions />
    <DefaultTemplate></DefaultTemplate>
    <AllowedTemplates />
  </Info>
  <Structure />
