<?xml version="1.0" encoding="utf-8"?>
<Template Key="c1a2b3c4-1010-0010-0010-000000000050" Alias="lgStepByStep" Level="1">
  <Name>LG Step By Step</Name>
  <Parent></Parent>
  <Contents><![CDATA[@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Extensions
@{
    Layout = "_Layout.cshtml";
    var steps = Model.Children?.Where(c => c.IsVisible()).ToList()
                ?? new List<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>();
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">@Model.Name</h1>

        @if (Model.HasValue("summary"))
        {
            <p class="govuk-body-l">@Model.Value("summary")</p>
        }

        <div class="app-step-nav app-step-nav--large app-step-nav--active" data-show-text="Show" data-hide-text="Hide" data-show-all-text="Show all steps" data-hide-all-text="Hide all steps">
            <ol class="app-step-nav__steps">
                @for (var i = 0; i < steps.Count; i++)
                {
                    var step = steps[i];
                    var stepNumber = i + 1;
                    var stepId = $"step-panel-{step.Key}";
                    <li class="app-step-nav__step" id="@stepId">
                        <div class="app-step-nav__header" data-position="@stepNumber">
                            <h2 class="app-step-nav__title">
                                <span class="app-step-nav__circle app-step-nav__circle--number">
                                    <span class="app-step-nav__circle-inner">
                                        <span class="app-step-nav__circle-background">
                                            <span class="govuk-visually-hidden govuk-!-display-none-print">Step </span>@stepNumber
                                        </span>
                                    </span>
                                </span>
                                <span class="js-step-title">@step.Name</span>
                            </h2>
                        </div>
                        <div class="app-step-nav__panel js-panel" id="step-panel-@step.Key-1">
                            @if (step.HasValue("main"))
                            {
                                <div class="govuk-body">@Html.Raw(step.Value("main"))</div>
                            }
                            @{
                                var cta = step.Value<Umbraco.Cms.Core.Models.Link>("callToAction");
                            }
                            @if (cta is not null)
                            {
                                <p class="govuk-body">
                                    <a class="govuk-link" href="@cta.Url" @(cta.Target is not null ? $"target=\"{cta.Target}\"" : "")>
                                        @cta.Name
                                    </a>
                                </p>
                            }
                        </div>
                    </li>
                }
            </ol>
        </div>
    </div>
</div>
]]></Contents>
</Template>
