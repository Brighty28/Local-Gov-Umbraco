@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Extensions
<!DOCTYPE html>
<html lang="en" class="govuk-template">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@(ViewData["Title"] ?? Model?.Name) - @(ViewData["SiteName"] ?? "LocalGov Umbraco")</title>

    <link rel="stylesheet" href="/css/localgov.css" />

    @RenderSection("Head", required: false)

    <style>
        :root {
            --localgov-primary-colour: @(ViewData["PrimaryColour"] ?? "#1d70b8");
            --localgov-secondary-colour: @(ViewData["SecondaryColour"] ?? "#003078");
        }
    </style>
</head>
<body class="govuk-template__body">

    <script>document.body.className = ((document.body.className) ? document.body.className + ' js-enabled' : 'js-enabled');</script>

    <a href="#main-content" class="govuk-skip-link" data-module="govuk-skip-link">Skip to main content</a>

    <header class="govuk-header" role="banner" data-module="govuk-header">
        <div class="govuk-header__container govuk-width-container">
            <div class="govuk-header__logo">
                <a href="/" class="govuk-header__link govuk-header__link--homepage">
                    @if (ViewData["LogoUrl"] != null)
                    {
                        <img src="@ViewData["LogoUrl"]" alt="@(ViewData["SiteName"] ?? "Home")" class="govuk-header__logotype">
                    }
                    else
                    {
                        <span class="govuk-header__logotype">@(ViewData["SiteName"] ?? "LocalGov Umbraco")</span>
                    }
                </a>
            </div>
            @RenderSection("HeaderNav", required: false)
        </div>
    </header>

    @RenderSection("AlertBanner", required: false)

    <div class="govuk-width-container">
        @RenderSection("Breadcrumb", required: false)

        <main class="govuk-main-wrapper" id="main-content" role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="govuk-footer" role="contentinfo">
        <div class="govuk-width-container">
            @RenderSection("Footer", required: false)
            <div class="govuk-footer__meta">
                <div class="govuk-footer__meta-item govuk-footer__meta-item--grow">
                    <h2 class="govuk-visually-hidden">Support links</h2>
                    @RenderSection("FooterLinks", required: false)
                </div>
            </div>
        </div>
    </footer>

    <script type="module">
        import { initAll } from '/js/localgov.js'
        initAll()
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
