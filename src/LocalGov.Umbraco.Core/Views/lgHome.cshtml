@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Extensions
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var servicePages = Model.Children?.Where(c => c.IsVisible()
        && c.ContentType.Alias.StartsWith("lgService", StringComparison.OrdinalIgnoreCase)).ToList()
        ?? new List<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>();
    var heroImage = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroImage");
    var heroAlt = heroImage?.Value<string>("altText") ?? string.Empty;
}

@if (heroImage is not null)
{
    <div class="govuk-!-margin-bottom-6">
        <img src="@heroImage.Url()" alt="@heroAlt" class="govuk-!-width-full" />
    </div>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">@Model.Name</h1>
        @if (Model.HasValue("summary"))
        {
            <p class="govuk-body-l">@Model.Value("summary")</p>
        }
        @if (Model.HasValue("main"))
        {
            <div class="govuk-body">@Html.Raw(Model.Value("main"))</div>
        }
    </div>
</div>

@if (servicePages.Any())
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            <h2 class="govuk-heading-l">Services</h2>
            @await Component.InvokeAsync("ServiceNavCards", new { page = Model })
        </div>
    </div>
}

@await Component.InvokeAsync("HomepageNewsList", new { count = 3 })
