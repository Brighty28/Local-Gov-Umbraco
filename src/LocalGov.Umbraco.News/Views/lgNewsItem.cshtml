@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Extensions
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var publishDate = Model.Value<DateTime?>("publishDate") ?? Model.CreateDate;
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <p class="govuk-body-s govuk-!-colour-secondary-text-on-light">
            <time datetime="@publishDate.ToString("yyyy-MM-dd")">
                @publishDate.ToString("d MMMM yyyy")
            </time>
        </p>

        <h1 class="govuk-heading-xl">@Model.Name</h1>

        @if (Model.HasValue("summary"))
        {
            <p class="govuk-body-l">@Model.Value("summary")</p>
        }

        @{
            var heroImage = Model.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("heroImage");
            var heroAlt = heroImage?.Value<string>("altText") ?? string.Empty;
        }
        @if (heroImage is not null)
        {
            <figure class="govuk-!-margin-bottom-6">
                <img src="@heroImage.Url()" alt="@heroAlt" class="govuk-!-width-full" />
            </figure>
        }

        @if (Model.HasValue("main"))
        {
            <div class="govuk-body">@Html.Raw(Model.Value("main"))</div>
        }

        <p class="govuk-body-s">
            <a class="govuk-link" href="@(Model.Parent?.Url() ?? "/news")">
                Back to news
            </a>
        </p>

    </div>
</div>
