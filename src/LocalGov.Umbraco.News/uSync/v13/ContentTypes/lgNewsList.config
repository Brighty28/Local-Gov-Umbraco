    <DefaultTemplate>lgNewsList</DefaultTemplate>
    <AllowedTemplates>
      <Template>lgNewsList</Template>
    </AllowedTemplates>
  </Info>
  <Structure>
    <ContentType>lgNewsItem</ContentType>
  </Structure>
  <GenericProperties>
