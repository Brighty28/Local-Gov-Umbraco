<?xml version="1.0" encoding="utf-8"?>
<Template Key="c1a2b3c4-1010-0010-0010-000000000041" Alias="lgGuidePage" Level="1">
  <Name>LG Guide Page</Name>
  <Parent></Parent>
  <Contents><![CDATA[@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Extensions
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var guide = Model.Parent;
    var siblings = guide?.Children?.Where(c => c.IsVisible()).ToList() ?? new List<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>();
    var currentIndex = siblings.IndexOf(Model);
    var prev = currentIndex > 0 ? siblings[currentIndex - 1] : guide;
    var next = currentIndex >= 0 && currentIndex < siblings.Count - 1 ? siblings[currentIndex + 1] : null;
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-xl">@guide?.Name</span>
        <h1 class="govuk-heading-xl">@Model.Name</h1>

        @if (Model.HasValue("main"))
        {
            <div class="govuk-body">@Html.Raw(Model.Value("main"))</div>
        }

        <nav class="govuk-!-margin-top-6" aria-label="Guide pagination">
            <div class="govuk-grid-row">
                @if (prev is not null)
                {
                    <div class="govuk-grid-column-one-half">
                        <a class="govuk-link" href="@prev.Url()" rel="prev">
                            <span class="govuk-body-s">Previous</span><br />
                            @(prev.Value<string>("navTitle") ?? prev.Name)
                        </a>
                    </div>
                }
                @if (next is not null)
                {
                    <div class="govuk-grid-column-one-half govuk-!-text-align-right">
                        <a class="govuk-link" href="@next.Url()" rel="next">
                            <span class="govuk-body-s">Next</span><br />
                            @(next.Value<string>("navTitle") ?? next.Name)
                        </a>
                    </div>
                }
            </div>
        </nav>
    </div>

    <div class="govuk-grid-column-one-third">
        @await Component.InvokeAsync("GuideNav", new { currentPage = Model })
    </div>
</div>
]]></Contents>
</Template>
