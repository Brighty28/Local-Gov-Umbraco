{
  "name": "localgov-theme",
  "version": "1.0.0",
  "private": true,
  "description": "SCSS + Tailwind source workspace for the LocalGov Umbraco theme. Compiles to ../src/LocalGov.Umbraco.Theme/wwwroot/localgov/theme/localgov.css. Dev-only — not shipped in any NuGet package.",
  "scripts": {
    "build:scss": "sass scss/main.scss .tmp/scss.css --no-source-map --style=expanded",
    "build:css": "postcss main.css -o ../src/LocalGov.Umbraco.Theme/wwwroot/localgov/theme/localgov.css",
    "build": "npm run build:scss && npm run build:css",
    "watch:scss": "sass scss/main.scss .tmp/scss.css --no-source-map --style=expanded --watch",
    "watch:css": "postcss main.css -o ../src/LocalGov.Umbraco.Theme/wwwroot/localgov/theme/localgov.css --watch",
    "watch": "npm-run-all --parallel watch:scss watch:css"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "sass": "^1.81.0",
    "tailwindcss": "^3.4.16"
  }
}
