{
  "name": "localgov-theme",
  "version": "1.0.0",
  "private": true,
  "description": "SCSS + Tailwind source workspace for LocalGov Umbraco themes. Each theme compiles to its own CSS file in ../src/LocalGov.Umbraco.Theme/wwwroot/localgov/theme/. Dev-only — not shipped in any NuGet package.",
  "scripts": {
    "build:default:scss": "sass scss/main.scss .tmp/default-scss.css --no-source-map --style=expanded",
    "build:default:css": "postcss main.css -o ../src/LocalGov.Umbraco.Theme/wwwroot/localgov/theme/localgov.css",
    "build:default": "npm run build:default:scss && npm run build:default:css",
    "build:verdant:scss": "sass themes/verdant/scss/main.scss themes/verdant/.tmp/scss.css --no-source-map --style=expanded",
    "build:verdant:css": "postcss themes/verdant/main.css -o ../src/LocalGov.Umbraco.Theme/wwwroot/localgov/theme/verdant.css",
    "build:verdant": "npm run build:verdant:scss && npm run build:verdant:css",
    "build": "npm-run-all build:default build:verdant",
    "watch:default": "npm-run-all --parallel \"build:default:scss -- --watch\" \"build:default:css -- --watch\"",
    "watch:verdant": "npm-run-all --parallel \"build:verdant:scss -- --watch\" \"build:verdant:css -- --watch\"",
    "watch": "npm-run-all --parallel watch:default watch:verdant"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "sass": "^1.81.0",
    "tailwindcss": "^3.4.16"
  }
}
